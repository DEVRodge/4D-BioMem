# 4D-BioMem 环境变量模板
# 复制为 .env 并填写实际值
# cp .env.example .env

# ── LLM 后端（留空 = mock 模式，无需 API Key）──
# LLM_BACKEND=mock  → 使用 keyword 规则（零依赖，适合本地测试）
# LLM_BACKEND=openai → 使用 OpenAI API（需配 OPENAI_API_KEY）
LLM_BACKEND=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── 服务鉴权（留空 = 无鉴权，受限网络中使用）──
API_KEY=

# ── 存储路径（容器内路径，Docker 自动挂载 volume）──
DB_PATH=/data/biomem.db
VECTOR_PATH=/data/vector_store

# ── 算法超参 ──
LAMBDA=0.05
THETA_PRUNE=0.5
TAU=1.0

# ── 日志 ──
LOG_LEVEL=info
